---
import '../../../styles/global.css';
import { getEventBySlug } from '../../../../data/events';
import PreviewPane from '../../../components/customize/PreviewPane.astro';
import EditorPanel from '../../../components/customize/EditorPanel.astro';
import SiteHead from '../../../components/SiteHead.astro';
import CaptionPopup from '../../../components/magicui/CaptionPopup.astro';

const eventSlug = Astro.params.eventSlug ?? '';
const event = getEventBySlug(eventSlug);

if (!event) {
  return Astro.redirect('/');
}

const requestedFrameId = Astro.url.searchParams.get('frameId') ?? '';
const selectedFrame =
  event.frames.find((frame) => frame.id === requestedFrameId) ?? event.frames[0];

const pageTitle = `Customize | ${event.title} | DP Blast`;
const pageDescription = `Customize your ${event.title} profile frame with zoom, position, and tilt controls.`;
---

<html lang="en" class="scroll-smooth">
  <head>
    <SiteHead
      title={pageTitle}
      description={pageDescription}
      imagePath={selectedFrame?.thumbnailPath ?? '/cosmos_dp_blast.png'}
    />
  </head>
  <body class="relative min-h-screen overflow-x-hidden bg-[#f8f9fa] font-['Outfit','Segoe_UI',sans-serif] text-[#202124] [--nav-h:4.5rem] max-sm:[--nav-h:4rem]">
    <div class="pointer-events-none fixed inset-0 -z-20" aria-hidden="true">
      <div class="absolute left-[12%] top-[18%] h-36 w-36 rounded-full bg-[#4285f4]/15 blur-3xl"></div>
      <div class="absolute right-[8%] top-[12%] h-28 w-28 rounded-full bg-[#fbbc04]/12 blur-2xl"></div>
      <div class="absolute bottom-[16%] right-[12%] h-40 w-40 rounded-full bg-[#34a853]/12 blur-3xl"></div>
    </div>

    <header class="sticky top-0 z-20 h-(--nav-h) border-b border-gray-200/90 bg-white/85 px-[clamp(1rem,3vw,2.5rem)] backdrop-blur-md max-sm:px-3.5">
      <div class="mx-auto flex h-full w-full max-w-7xl items-center justify-between">
        <a class="inline-flex items-center no-underline" href="/" aria-label="GDG Frames home">
          <img src="/logo.png" alt="DP Blast" class="h-10 w-auto max-sm:h-8" loading="eager" decoding="async" />
        </a>
        <div class="flex items-center gap-2.5">
          <button
            type="button"
            data-edit-name-trigger
            class="inline-flex items-center justify-center rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-bold text-gray-700 shadow-[0_8px_20px_rgba(17,24,39,0.07)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-gray-50"
          >
            Edit Name
          </button>
          <a
            class="inline-flex items-center justify-center rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-bold text-gray-700 no-underline shadow-[0_8px_20px_rgba(17,24,39,0.07)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-gray-50"
            href={`/events/${event.slug}`}
          >
            Back to uploader
          </a>
        </div>
      </div>
    </header>

    <main class="relative z-10 py-8 max-sm:pb-10 brand-grid-bg brand-grid-bg--fade">
      <section class="mx-auto w-full max-w-7xl px-4" aria-label="Customize your DP frame">
        <div class="rounded-4xl border border-gray-200 bg-white p-4 shadow-[0_20px_60px_rgba(17,24,39,0.14)] md:p-7 lg:p-9">
          <div class="grid gap-8 lg:grid-cols-[minmax(320px,480px)_1fr] lg:gap-12">
            <div class="order-2 lg:order-1">
              <PreviewPane frames={event.frames} selectedFrameId={selectedFrame.id} />
            </div>
            <div class="order-1 lg:order-2">
              <EditorPanel eventTitle={event.title} />
            </div>
          </div>
          <div class="flex justify-center mx-auto w-full sm:max-w-[480px] md:max-w-none">
            <button
              id="download-result"
              type="button"
              class="mt-2 inline-flex items-center justify-center rounded-full bg-(--google-green) px-5 py-3 text-sm font-bold w-full text-white shadow-[0_12px_24px_rgba(66,133,244,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5"
            >
              Download Customized DP
            </button>
          </div>

        </div>
      </section>
    </main>

    <div
      id="customize-config"
      data-event-slug={event.slug}
      data-caption-template={event.captionTemplate}
      data-initial-frame-id={selectedFrame.id}
      hidden
      aria-hidden="true"
    ></div>

    <CaptionPopup />

    <script is:inline>
      // @ts-nocheck
      const MAX_UPLOAD_BYTES = 10 * 1024 * 1024;
      const MAX_PREVIEW_EDGE = 1024;
      const MAX_EXPORT_EDGE = 2048;
      const ALLOWED_TYPES = new Set(['image/png', 'image/jpeg', 'image/webp']);
      const SESSION_IMAGE_KEY = 'dpblast-customize-image';
      const HOLD_TIP_SEEN_KEY = 'dpblast-hold-controls-tip-seen';
      const PINCH_TIP_SEEN_KEY = 'dpblast-pinch-tip-seen';
      const USER_NAME_KEY = 'dpblast-user-name';

      const initCustomizePage = ({ eventSlug, captionTemplate, initialFrameId }) => {
        let selectedFrameId = initialFrameId;
        let activePhotoImage = null;
        let activeFrameImage = null;
        let renderScheduled = false;

        const state = {
          zoom: 1,
          offsetX: 0,
          offsetY: 0,
          tiltDeg: 0,
        };

        const canvas = document.getElementById('preview-canvas');
        const statusEl = document.getElementById('canvas-status');
        const frameButtons = document.querySelectorAll('.customize-frame-btn');
        const photoInput = document.getElementById('photo');
        const resetButton = document.getElementById('reset-adjustments');
        const downloadButton = document.getElementById('download-result');
        const zoomOutQuickButton = document.getElementById('zoom-out-quick');
        const zoomInQuickButton = document.getElementById('zoom-in-quick');
        const moveLeftQuickButton = document.getElementById('move-left-quick');
        const moveUpQuickButton = document.getElementById('move-up-quick');
        const moveRightQuickButton = document.getElementById('move-right-quick');
        const moveDownQuickButton = document.getElementById('move-down-quick');
        const rotateLeftQuickButton = document.getElementById('rotate-left-quick');
        const rotateRightQuickButton = document.getElementById('rotate-right-quick');
        const resetQuickButton = document.getElementById('reset-quick');
        const holdControlsTip = document.getElementById('hold-controls-tip');
        const holdControlsTipDismiss = document.getElementById('hold-controls-tip-dismiss');
        const pinchGestureTip = document.getElementById('pinch-gesture-tip');
        const captionPopup = document.getElementById('caption-popup');
        const captionPopupBackdrop = document.getElementById('caption-popup-backdrop');
        const captionPopupText = document.getElementById('caption-popup-text');
        const captionPopupStatus = document.getElementById('caption-popup-status');
        const captionPopupCopyButton = document.getElementById('caption-popup-copy');
        const captionPopupCloseButton = document.getElementById('caption-popup-close');

        const zoomRange = document.getElementById('zoom-range');
        const xRange = document.getElementById('x-range');
        const yRange = document.getElementById('y-range');
        const tiltRange = document.getElementById('tilt-range');

        const zoomValue = document.getElementById('zoom-value');
        const xValue = document.getElementById('x-value');
        const yValue = document.getElementById('y-value');
        const tiltValue = document.getElementById('tilt-value');

        const ctx =
          canvas instanceof HTMLCanvasElement ? canvas.getContext('2d') : null;

        const setCanvasStatus = (message, isError = false) => {
          if (!(statusEl instanceof HTMLParagraphElement)) return;
          statusEl.textContent = message;
          statusEl.className = isError
            ? 'mt-3 text-sm text-red-600'
            : 'mt-3 text-sm text-gray-600';
        };

        const setDownloadLoading = (isLoading) => {
          if (!(downloadButton instanceof HTMLButtonElement)) return;

          if (isLoading) {
            downloadButton.disabled = true;
            downloadButton.textContent = 'Preparing download...';
            downloadButton.classList.add('opacity-70', 'cursor-not-allowed');
            return;
          }

          downloadButton.disabled = false;
          downloadButton.textContent = 'Download Customized DP';
          downloadButton.classList.remove('opacity-70', 'cursor-not-allowed');
        };

        const updateValueLabels = () => {
          if (zoomValue instanceof HTMLSpanElement)
            zoomValue.textContent = `${state.zoom.toFixed(2)}x`;
          if (xValue instanceof HTMLSpanElement)
            xValue.textContent = `${Math.round(state.offsetX)}px`;
          if (yValue instanceof HTMLSpanElement)
            yValue.textContent = `${Math.round(state.offsetY)}px`;
          if (tiltValue instanceof HTMLSpanElement)
            tiltValue.textContent = `${Math.round(state.tiltDeg)}deg`;
        };

        const getStoredVisitorName = () => {
          try {
            const storedName = localStorage.getItem(USER_NAME_KEY);
            if (storedName && storedName.trim()) {
              return storedName.trim();
            }
          } catch {
            // Ignore storage errors and use fallback.
          }

          return 'Sparkmate';
        };

        const buildCaption = (nameValue) => {
          const safeName = nameValue && nameValue.trim() ? nameValue.trim() : 'Sparkmate';
          return captionTemplate.replaceAll('{{name}}', safeName);
        };

        const getRangeBounds = (input, fallbackMin, fallbackMax) => {
          if (!(input instanceof HTMLInputElement)) {
            return { min: fallbackMin, max: fallbackMax };
          }

          const min = Number(input.min);
          const max = Number(input.max);

          return {
            min: Number.isFinite(min) ? min : fallbackMin,
            max: Number.isFinite(max) ? max : fallbackMax,
          };
        };

        const clamp = (value, min, max) => {
          return Math.min(max, Math.max(min, value));
        };

        const loadImage = (src) =>
          new Promise((resolve, reject) => {
            const image = new Image();
            image.onload = () => resolve(image);
            image.onerror = () => reject(new Error('image-load-failed'));
            image.src = src;
          });

        const getTargetSize = (sourceWidth, sourceHeight, maxEdge) => {
          const width = sourceWidth || 1080;
          const height = sourceHeight || 1080;
          const scaleFactor = Math.min(1, maxEdge / Math.max(width, height));
          return {
            width: Math.max(1, Math.round(width * scaleFactor)),
            height: Math.max(1, Math.round(height * scaleFactor)),
          };
        };

        const drawComposite = ({
          targetCtx,
          canvasWidth,
          canvasHeight,
          photoImage,
          frameImage,
          offsetScaleX,
          offsetScaleY,
        }) => {
          targetCtx.clearRect(0, 0, canvasWidth, canvasHeight);

          if (photoImage instanceof HTMLImageElement) {
            const baseScale = Math.max(
              canvasWidth / photoImage.naturalWidth,
              canvasHeight / photoImage.naturalHeight,
            );
            const finalScale = baseScale * state.zoom;
            const drawWidth = photoImage.naturalWidth * finalScale;
            const drawHeight = photoImage.naturalHeight * finalScale;

            targetCtx.save();
            targetCtx.translate(
              canvasWidth / 2 + state.offsetX * offsetScaleX,
              canvasHeight / 2 + state.offsetY * offsetScaleY,
            );
            targetCtx.rotate((state.tiltDeg * Math.PI) / 180);
            targetCtx.drawImage(
              photoImage,
              -drawWidth / 2,
              -drawHeight / 2,
              drawWidth,
              drawHeight,
            );
            targetCtx.restore();
          } else {
            targetCtx.fillStyle = '#e5e7eb';
            targetCtx.fillRect(0, 0, canvasWidth, canvasHeight);
            targetCtx.fillStyle = '#6b7280';
            targetCtx.font = '600 24px Outfit, Segoe UI, sans-serif';
            targetCtx.textAlign = 'center';
            targetCtx.fillText('Upload a photo to begin', canvasWidth / 2, canvasHeight / 2);
          }

          targetCtx.drawImage(frameImage, 0, 0, canvasWidth, canvasHeight);
        };

        const canvasToBlob = (sourceCanvas, mimeType) =>
          new Promise((resolve) => {
            sourceCanvas.toBlob((blob) => resolve(blob), mimeType);
          });

        const createDownloadBlob = async () => {
          if (!(activeFrameImage instanceof HTMLImageElement)) {
            throw new Error('frame-not-ready');
          }

          const targetSize = getTargetSize(
            activeFrameImage.naturalWidth,
            activeFrameImage.naturalHeight,
            MAX_EXPORT_EDGE,
          );

          const exportCanvas = document.createElement('canvas');
          exportCanvas.width = targetSize.width;
          exportCanvas.height = targetSize.height;

          const exportCtx = exportCanvas.getContext('2d');
          if (!exportCtx) {
            throw new Error('canvas-context-unavailable');
          }

          const previewWidth = canvas instanceof HTMLCanvasElement ? canvas.width : targetSize.width;
          const previewHeight = canvas instanceof HTMLCanvasElement ? canvas.height : targetSize.height;
          const offsetScaleX = previewWidth > 0 ? targetSize.width / previewWidth : 1;
          const offsetScaleY = previewHeight > 0 ? targetSize.height / previewHeight : 1;

          drawComposite({
            targetCtx: exportCtx,
            canvasWidth: targetSize.width,
            canvasHeight: targetSize.height,
            photoImage: activePhotoImage,
            frameImage: activeFrameImage,
            offsetScaleX,
            offsetScaleY,
          });

          const pngBlob = await canvasToBlob(exportCanvas, 'image/png');
          if (pngBlob) {
            return { blob: pngBlob, extension: 'png' };
          }

          throw new Error('blob-export-failed');
        };

        const getFrameButtonById = (frameId) =>
          Array.from(frameButtons).find((button) => {
            return (
              button instanceof HTMLButtonElement && button.dataset.frameId === frameId
            );
          });

        const highlightFrame = (frameId) => {
          frameButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) {
              button.classList.remove('ring-2', 'ring-[#4285f4]');
              if (button.dataset.frameId === frameId) {
                button.classList.add('ring-2', 'ring-[#4285f4]');
              }
            }
          });
        };

        const performRender = () => {
          if (
            !(canvas instanceof HTMLCanvasElement) ||
            !ctx ||
            !(activeFrameImage instanceof HTMLImageElement)
          ) {
            return;
          }

          const previewSize = getTargetSize(
            activeFrameImage.naturalWidth,
            activeFrameImage.naturalHeight,
            MAX_PREVIEW_EDGE,
          );
          const width = previewSize.width;
          const height = previewSize.height;

          if (canvas.width !== width || canvas.height !== height) {
            canvas.width = width;
            canvas.height = height;
          }

          drawComposite({
            targetCtx: ctx,
            canvasWidth: width,
            canvasHeight: height,
            photoImage: activePhotoImage,
            frameImage: activeFrameImage,
            offsetScaleX: 1,
            offsetScaleY: 1,
          });
        };

        const renderCanvas = () => {
          if (renderScheduled) return;
          renderScheduled = true;
          window.requestAnimationFrame(() => {
            renderScheduled = false;
            performRender();
          });
        };

        const setFrameFromButton = async (button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const frameId = button.dataset.frameId;
          const overlayPath = button.dataset.frameOverlay;
          if (!frameId || !overlayPath) return;

          selectedFrameId = frameId;
          activeFrameImage = await loadImage(overlayPath);
          highlightFrame(frameId);
          renderCanvas();
        };

        const ensureFrameReady = async () => {
          if (activeFrameImage instanceof HTMLImageElement) {
            return true;
          }

          const selectedButton = getFrameButtonById(selectedFrameId);
          const fallbackButton = frameButtons[0];
          const buttonToLoad =
            selectedButton instanceof HTMLButtonElement
              ? selectedButton
              : fallbackButton instanceof HTMLButtonElement
                ? fallbackButton
                : null;

          if (!(buttonToLoad instanceof HTMLButtonElement)) {
            return false;
          }

          await setFrameFromButton(buttonToLoad);
          return activeFrameImage instanceof HTMLImageElement;
        };

        const toDataUrl = (file) =>
          new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => {
              if (typeof reader.result === 'string') {
                resolve(reader.result);
              } else {
                reject(new Error('invalid-data-url'));
              }
            };
            reader.onerror = () => reject(new Error('file-read-failed'));
            reader.readAsDataURL(file);
          });

        const readPersistedImage = () => {
          try {
            const raw = sessionStorage.getItem(SESSION_IMAGE_KEY);
            if (!raw) return null;
            const parsed = JSON.parse(raw);
            if (parsed?.eventSlug !== eventSlug || typeof parsed?.dataUrl !== 'string') {
              return null;
            }
            return parsed;
          } catch {
            return null;
          }
        };

        const persistImage = (fileName, mimeType, dataUrl) => {
          sessionStorage.setItem(
            SESSION_IMAGE_KEY,
            JSON.stringify({
              eventSlug,
              fileName,
              mimeType,
              dataUrl,
            }),
          );
        };

        const applyPhotoFromDataUrl = async (dataUrl) => {
          activePhotoImage = await loadImage(dataUrl);
          renderCanvas();
        };

        const syncRangeInputs = () => {
          if (zoomRange instanceof HTMLInputElement) {
            zoomRange.value = state.zoom.toFixed(2);
          }
          if (xRange instanceof HTMLInputElement) {
            xRange.value = String(Math.round(state.offsetX));
          }
          if (yRange instanceof HTMLInputElement) {
            yRange.value = String(Math.round(state.offsetY));
          }
          if (tiltRange instanceof HTMLInputElement) {
            tiltRange.value = String(Math.round(state.tiltDeg));
          }
        };

        const bindRange = (input, apply) => {
          if (!(input instanceof HTMLInputElement)) return;
          input.addEventListener('input', () => {
            apply(Number(input.value));
            updateValueLabels();
            renderCanvas();
          });
        };

        const resetAdjustments = () => {
          state.zoom = 1;
          state.offsetX = 0;
          state.offsetY = 0;
          state.tiltDeg = 0;

          if (zoomRange instanceof HTMLInputElement) zoomRange.value = '1';
          if (xRange instanceof HTMLInputElement) xRange.value = '0';
          if (yRange instanceof HTMLInputElement) yRange.value = '0';
          if (tiltRange instanceof HTMLInputElement) tiltRange.value = '0';

          updateValueLabels();
          renderCanvas();
        };

        const applyZoomDelta = (delta) => {
          const { min, max } = getRangeBounds(zoomRange, 0.5, 2.8);
          const next = Math.min(max, Math.max(min, state.zoom + delta));
          state.zoom = Number(next.toFixed(2));

          if (zoomRange instanceof HTMLInputElement) {
            zoomRange.value = state.zoom.toFixed(2);
          }

          updateValueLabels();
          renderCanvas();
        };

        const applyTiltDelta = (delta) => {
          const { min, max } = getRangeBounds(tiltRange, -180, 180);
          const next = Math.min(max, Math.max(min, state.tiltDeg + delta));
          state.tiltDeg = Math.round(next);

          if (tiltRange instanceof HTMLInputElement) {
            tiltRange.value = String(state.tiltDeg);
          }

          updateValueLabels();
          renderCanvas();
        };

        const applyOffsetDelta = (axis, delta) => {
          const targetRange = axis === 'x' ? xRange : yRange;
          const { min, max } = getRangeBounds(targetRange, -500, 500);

          if (axis === 'x') {
            state.offsetX = Math.min(max, Math.max(min, state.offsetX + delta));
            if (xRange instanceof HTMLInputElement) {
              xRange.value = String(Math.round(state.offsetX));
            }
          } else {
            state.offsetY = Math.min(max, Math.max(min, state.offsetY + delta));
            if (yRange instanceof HTMLInputElement) {
              yRange.value = String(Math.round(state.offsetY));
            }
          }

          updateValueLabels();
          renderCanvas();
        };

        const bindTapOrHold = (button, action, statusMessage) => {
          let holdTimeoutId = null;
          let holdIntervalId = null;
          let consumedByHold = false;

          const runAction = () => {
            action();
            setCanvasStatus(statusMessage);
          };

          const clearHoldTimers = () => {
            if (holdTimeoutId !== null) {
              window.clearTimeout(holdTimeoutId);
              holdTimeoutId = null;
            }
            if (holdIntervalId !== null) {
              window.clearInterval(holdIntervalId);
              holdIntervalId = null;
            }
          };

          const startHold = (event) => {
            if (event instanceof MouseEvent && event.button !== 0) {
              return;
            }

            event.preventDefault();
            consumedByHold = false;
            clearHoldTimers();

            holdTimeoutId = window.setTimeout(() => {
              consumedByHold = true;
              runAction();
              holdIntervalId = window.setInterval(runAction, 85);
            }, 260);
          };

          const stopHold = () => {
            clearHoldTimers();
          };

          button.addEventListener('mousedown', startHold);
          button.addEventListener('touchstart', startHold, { passive: false });

          button.addEventListener('mouseup', stopHold);
          button.addEventListener('mouseleave', stopHold);
          button.addEventListener('touchend', stopHold);
          button.addEventListener('touchcancel', stopHold);

          button.addEventListener('click', (event) => {
            if (consumedByHold) {
              consumedByHold = false;
              event.preventDefault();
              return;
            }
            runAction();
          });
        };

        const maybeShowHoldTip = () => {
          if (!(holdControlsTip instanceof HTMLElement)) return;
          if (!window.matchMedia('(max-width: 639px)').matches) return;

          const hideTip = () => {
            holdControlsTip.classList.add('hidden');
            holdControlsTip.classList.remove('flex');
          };

          const markSeen = () => {
            try {
              localStorage.setItem(HOLD_TIP_SEEN_KEY, '1');
            } catch {
              // Ignore storage failures and continue with UI.
            }
          };

          try {
            if (localStorage.getItem(HOLD_TIP_SEEN_KEY) === '1') {
              hideTip();
              return;
            }
          } catch {
            // If storage is unavailable, still show tip for this visit.
          }

          holdControlsTip.classList.remove('hidden');
          holdControlsTip.classList.add('flex');
          markSeen();

          const quickButtons = [
            zoomOutQuickButton,
            zoomInQuickButton,
            moveLeftQuickButton,
            moveUpQuickButton,
            moveRightQuickButton,
            moveDownQuickButton,
            rotateLeftQuickButton,
            rotateRightQuickButton,
            resetQuickButton,
          ];

          quickButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) {
              button.addEventListener('click', hideTip, { once: true });
            }
          });

          if (holdControlsTipDismiss instanceof HTMLButtonElement) {
            holdControlsTipDismiss.addEventListener('click', () => {
              hideTip();
            });
          }

          window.setTimeout(hideTip, 5000);
        };

        const setupMobileGestureHint = () => {
          if (!(pinchGestureTip instanceof HTMLElement)) return;
          if (!window.matchMedia('(max-width: 639px)').matches) return;

          const hideTip = () => {
            pinchGestureTip.classList.add('hidden');
            pinchGestureTip.classList.remove('block');
          };

          try {
            if (localStorage.getItem(PINCH_TIP_SEEN_KEY) === '1') {
              hideTip();
              return;
            }
          } catch {
            // Continue and show once for this visit.
          }

          pinchGestureTip.classList.remove('hidden');
          pinchGestureTip.classList.add('block');

          window.setTimeout(() => {
            hideTip();
            try {
              localStorage.setItem(PINCH_TIP_SEEN_KEY, '1');
            } catch {
              // Ignore storage failures.
            }
          }, 4200);

          const dismissOnGestureStart = () => {
            hideTip();
            try {
              localStorage.setItem(PINCH_TIP_SEEN_KEY, '1');
            } catch {
              // Ignore storage failures.
            }
          };

          if (canvas instanceof HTMLCanvasElement) {
            canvas.addEventListener('touchstart', dismissOnGestureStart, { once: true });
          }
        };

        const setupTouchGestures = () => {
          if (!(canvas instanceof HTMLCanvasElement)) return;

          const activeTouches = new Map();
          let panStartPoint = null;
          let panStartOffsetX = 0;
          let panStartOffsetY = 0;
          let pinchStartDistance = 0;
          let pinchStartZoom = 1;
          let pinchStartMidpoint = { x: 0, y: 0 };
          let pinchStartOffsetX = 0;
          let pinchStartOffsetY = 0;

          const toCanvasPoint = (touch) => {
            const rect = canvas.getBoundingClientRect();
            const safeWidth = rect.width || 1;
            const safeHeight = rect.height || 1;
            return {
              x: ((touch.clientX - rect.left) / safeWidth) * canvas.width,
              y: ((touch.clientY - rect.top) / safeHeight) * canvas.height,
            };
          };

          const getFirstTwoTouches = () => {
            const values = Array.from(activeTouches.values());
            if (values.length < 2) return null;
            return [values[0], values[1]];
          };

          const getDistance = (a, b) => Math.hypot(b.x - a.x, b.y - a.y);
          const getMidpoint = (a, b) => ({
            x: (a.x + b.x) / 2,
            y: (a.y + b.y) / 2,
          });

          const beginPan = (point) => {
            panStartPoint = point;
            panStartOffsetX = state.offsetX;
            panStartOffsetY = state.offsetY;
          };

          const beginPinch = () => {
            const touches = getFirstTwoTouches();
            if (!touches) return;

            const [first, second] = touches;
            pinchStartDistance = Math.max(1, getDistance(first, second));
            pinchStartZoom = state.zoom;
            pinchStartMidpoint = getMidpoint(first, second);
            pinchStartOffsetX = state.offsetX;
            pinchStartOffsetY = state.offsetY;
          };

          const applyPan = (point) => {
            if (!panStartPoint) return;

            const xBounds = getRangeBounds(xRange, -500, 500);
            const yBounds = getRangeBounds(yRange, -500, 500);

            const deltaX = point.x - panStartPoint.x;
            const deltaY = point.y - panStartPoint.y;

            state.offsetX = clamp(panStartOffsetX + deltaX, xBounds.min, xBounds.max);
            state.offsetY = clamp(panStartOffsetY + deltaY, yBounds.min, yBounds.max);
            syncRangeInputs();
            updateValueLabels();
            renderCanvas();
          };

          const applyPinch = () => {
            const touches = getFirstTwoTouches();
            if (!touches) return;

            const [first, second] = touches;
            const zoomBounds = getRangeBounds(zoomRange, 0.5, 2.8);
            const xBounds = getRangeBounds(xRange, -500, 500);
            const yBounds = getRangeBounds(yRange, -500, 500);

            const distance = Math.max(1, getDistance(first, second));
            const midpoint = getMidpoint(first, second);

            const nextZoom = clamp(
              pinchStartZoom * (distance / pinchStartDistance),
              zoomBounds.min,
              zoomBounds.max,
            );

            state.zoom = Number(nextZoom.toFixed(2));
            state.offsetX = clamp(
              pinchStartOffsetX + (midpoint.x - pinchStartMidpoint.x),
              xBounds.min,
              xBounds.max,
            );
            state.offsetY = clamp(
              pinchStartOffsetY + (midpoint.y - pinchStartMidpoint.y),
              yBounds.min,
              yBounds.max,
            );

            syncRangeInputs();
            updateValueLabels();
            renderCanvas();
          };

          const onTouchStart = (event) => {
            Array.from(event.changedTouches).forEach((touch) => {
              activeTouches.set(touch.identifier, toCanvasPoint(touch));
            });

            if (activeTouches.size >= 2) {
              event.preventDefault();
              beginPinch();
              panStartPoint = null;
              return;
            }

            if (activeTouches.size === 1) {
              const point = Array.from(activeTouches.values())[0];
              beginPan(point);
            }
          };

          const onTouchMove = (event) => {
            Array.from(event.changedTouches).forEach((touch) => {
              if (activeTouches.has(touch.identifier)) {
                activeTouches.set(touch.identifier, toCanvasPoint(touch));
              }
            });

            if (activeTouches.size >= 2) {
              event.preventDefault();
              applyPinch();
              return;
            }

            if (activeTouches.size === 1) {
              event.preventDefault();
              const point = Array.from(activeTouches.values())[0];
              applyPan(point);
            }
          };

          const onTouchEnd = (event) => {
            Array.from(event.changedTouches).forEach((touch) => {
              activeTouches.delete(touch.identifier);
            });

            if (activeTouches.size >= 2) {
              beginPinch();
              return;
            }

            if (activeTouches.size === 1) {
              const point = Array.from(activeTouches.values())[0];
              beginPan(point);
              return;
            }

            panStartPoint = null;
          };

          canvas.addEventListener('touchstart', onTouchStart, { passive: false });
          canvas.addEventListener('touchmove', onTouchMove, { passive: false });
          canvas.addEventListener('touchend', onTouchEnd, { passive: false });
          canvas.addEventListener('touchcancel', onTouchEnd, { passive: false });
        };

        const setCaptionPopupStatus = (message, isError = false) => {
          if (!(captionPopupStatus instanceof HTMLParagraphElement)) return;
          captionPopupStatus.textContent = message;
          captionPopupStatus.className = isError
            ? 'm-0 mt-2 min-h-5 text-sm text-red-600'
            : 'm-0 mt-2 min-h-5 text-sm text-gray-600';
        };

        const openCaptionPopup = (caption) => {
          if (
            !(captionPopup instanceof HTMLDivElement) ||
            !(captionPopupText instanceof HTMLTextAreaElement)
          ) {
            return;
          }

          captionPopupText.value = caption;
          captionPopup.classList.remove('hidden');
          captionPopup.classList.add('flex');
          setCaptionPopupStatus('Caption is ready.');
        };

        const closeCaptionPopup = (redirectHome = false) => {
          if (!(captionPopup instanceof HTMLDivElement)) return;
          captionPopup.classList.add('hidden');
          captionPopup.classList.remove('flex');

          if (redirectHome) {
            window.location.href = '/';
          }
        };

        const trackDownload = () => {
          fetch('/api/analytics/download', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              eventSlug,
              frameId: selectedFrameId,
              sourcePath: window.location.pathname,
            }),
          }).catch(() => {
            // Ignore analytics failures so download flow remains uninterrupted.
          });
        };

        frameButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', async () => {
            try {
              await setFrameFromButton(button);
              setCanvasStatus('Frame updated.');
              const url = new URL(window.location.href);
              url.searchParams.set('frameId', selectedFrameId);
              window.history.replaceState({}, '', url.toString());
            } catch {
              setCanvasStatus('Could not switch frame. Please try again.', true);
            }
          });
        });

        bindRange(zoomRange, (value) => {
          state.zoom = value;
        });

        bindRange(xRange, (value) => {
          state.offsetX = value;
        });

        bindRange(yRange, (value) => {
          state.offsetY = value;
        });

        bindRange(tiltRange, (value) => {
          state.tiltDeg = value;
        });

        if (resetButton instanceof HTMLButtonElement) {
          resetButton.addEventListener('click', () => {
            resetAdjustments();
            setCanvasStatus('Adjustments reset.');
          });
        }

        if (zoomOutQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(zoomOutQuickButton, () => {
            applyZoomDelta(-0.1);
          }, 'Zoom updated.');
        }

        if (zoomInQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(zoomInQuickButton, () => {
            applyZoomDelta(0.1);
          }, 'Zoom updated.');
        }

        if (moveLeftQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(moveLeftQuickButton, () => {
            applyOffsetDelta('x', -15);
          }, 'Position updated.');
        }

        if (moveRightQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(moveRightQuickButton, () => {
            applyOffsetDelta('x', 15);
          }, 'Position updated.');
        }

        if (moveUpQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(moveUpQuickButton, () => {
            applyOffsetDelta('y', -15);
          }, 'Position updated.');
        }

        if (moveDownQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(moveDownQuickButton, () => {
            applyOffsetDelta('y', 15);
          }, 'Position updated.');
        }

        if (rotateLeftQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(rotateLeftQuickButton, () => {
            applyTiltDelta(-5);
          }, 'Tilt updated.');
        }

        if (rotateRightQuickButton instanceof HTMLButtonElement) {
          bindTapOrHold(rotateRightQuickButton, () => {
            applyTiltDelta(5);
          }, 'Tilt updated.');
        }

        if (resetQuickButton instanceof HTMLButtonElement) {
          resetQuickButton.addEventListener('click', () => {
            resetAdjustments();
            setCanvasStatus('Adjustments reset.');
          });
        }

        if (photoInput instanceof HTMLInputElement) {
          photoInput.addEventListener('change', async () => {
            const file = photoInput.files?.[0];
            if (!file) return;

            if (!ALLOWED_TYPES.has(file.type)) {
              setCanvasStatus(
                'Unsupported file type. Please use PNG, JPG, or WEBP.',
                true,
              );
              return;
            }

            if (file.size > MAX_UPLOAD_BYTES) {
              setCanvasStatus('File is too large. Maximum size is 10MB.', true);
              return;
            }

            try {
              setCanvasStatus('Preparing frame and photo...');
              const frameReady = await ensureFrameReady();
              if (!frameReady) {
                setCanvasStatus('Frame is still loading. Please try again in a moment.', true);
                return;
              }

              const dataUrl = await toDataUrl(file);
              await applyPhotoFromDataUrl(dataUrl);
              persistImage(file.name, file.type, dataUrl);
              setCanvasStatus('Photo loaded. Fine-tune and download when ready.');
            } catch {
              setCanvasStatus('Could not load the selected photo.', true);
            }
          });
        }

        if (downloadButton instanceof HTMLButtonElement) {
          downloadButton.addEventListener('click', async () => {
            if (!(canvas instanceof HTMLCanvasElement)) return;

            if (!(activePhotoImage instanceof HTMLImageElement)) {
              setCanvasStatus('Upload a photo before downloading.', true);
              return;
            }

            setDownloadLoading(true);

            try {
              const frameReady = await ensureFrameReady();
              if (!frameReady) {
                throw new Error('frame-not-ready');
              }

              const { blob, extension } = await createDownloadBlob();
              const blobUrl = URL.createObjectURL(blob);
              const anchor = document.createElement('a');
              anchor.href = blobUrl;
              anchor.download = `${eventSlug}-${selectedFrameId}-custom.${extension}`;
              document.body.appendChild(anchor);
              anchor.click();
              document.body.removeChild(anchor);
              URL.revokeObjectURL(blobUrl);
              trackDownload();
              setCanvasStatus('Download started.');

              const generatedCaption = buildCaption(getStoredVisitorName());
              openCaptionPopup(generatedCaption);
            } catch {
              setCanvasStatus('Download failed. Please try again.', true);
            } finally {
              setDownloadLoading(false);
            }
          });
        }

        if (
          captionPopupCopyButton instanceof HTMLButtonElement &&
          captionPopupText instanceof HTMLTextAreaElement
        ) {
          captionPopupCopyButton.addEventListener('click', async () => {
            const textToCopy = captionPopupText.value.trim();
            if (!textToCopy) {
              setCaptionPopupStatus('Caption is empty.', true);
              return;
            }

            try {
              if (navigator.clipboard?.writeText) {
                await navigator.clipboard.writeText(textToCopy);
              } else {
                captionPopupText.focus();
                captionPopupText.select();
                const copied = document.execCommand('copy');
                if (!copied) {
                  throw new Error('copy-failed');
                }
              }
              setCaptionPopupStatus('Caption copied. You can paste it now.');
            } catch {
              setCaptionPopupStatus('Copy failed. Please select and copy manually.', true);
            }
          });
        }

        if (captionPopupCloseButton instanceof HTMLButtonElement) {
          captionPopupCloseButton.addEventListener('click', () => closeCaptionPopup(true));
        }

        if (captionPopupBackdrop instanceof HTMLDivElement) {
          captionPopupBackdrop.addEventListener('click', () => closeCaptionPopup(true));
        }

        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeCaptionPopup(true);
          }
        });

        const bootstrap = async () => {
          const initialFrameButton = getFrameButtonById(selectedFrameId);
          const fallbackButton = frameButtons[0];

          try {
            if (initialFrameButton instanceof HTMLButtonElement) {
              await setFrameFromButton(initialFrameButton);
            } else if (fallbackButton instanceof HTMLButtonElement) {
              await setFrameFromButton(fallbackButton);
            }

            const persisted = readPersistedImage();
            if (persisted?.dataUrl) {
              await applyPhotoFromDataUrl(persisted.dataUrl);
              setCanvasStatus('Loaded your selected photo. Adjust and download when ready.');
            } else {
              renderCanvas();
              setCanvasStatus('Upload a photo to start customizing.');
            }
          } catch {
            setCanvasStatus('Could not initialize customization controls.', true);
          }
        };

        updateValueLabels();
        maybeShowHoldTip();
        setupMobileGestureHint();
        setupTouchGestures();
        bootstrap();
      };

      const configEl = document.getElementById('customize-config');
      const eventSlug = configEl?.getAttribute('data-event-slug') ?? '';
      const captionTemplate = configEl?.getAttribute('data-caption-template') ?? '';
      const initialFrameId = configEl?.getAttribute('data-initial-frame-id') ?? '';

      if (!eventSlug || !captionTemplate || !initialFrameId) {
        console.error('Customize page config is incomplete.');
      } else {
        initCustomizePage({
          eventSlug,
          captionTemplate,
          initialFrameId,
        });
      }
    </script>

    <style is:global>
      @keyframes pinch-hint-left {
        0% {
          transform: translateX(0) scale(1);
          opacity: 0.75;
        }
        50% {
          transform: translateX(-10px) scale(1.08);
          opacity: 1;
        }
        100% {
          transform: translateX(0) scale(1);
          opacity: 0.75;
        }
      }

      @keyframes pinch-hint-right {
        0% {
          transform: translateX(0) scale(1);
          opacity: 0.75;
        }
        50% {
          transform: translateX(10px) scale(1.08);
          opacity: 1;
        }
        100% {
          transform: translateX(0) scale(1);
          opacity: 0.75;
        }
      }

      .pinch-hint-dot {
        display: inline-block;
        height: 10px;
        width: 10px;
        border-radius: 9999px;
        background: #4285f4;
      }

      .pinch-hint-dot--left {
        animation: pinch-hint-left 1.1s ease-in-out infinite;
      }

      .pinch-hint-dot--right {
        animation: pinch-hint-right 1.1s ease-in-out infinite;
      }
    </style>
  </body>
</html>

---
type IconName = 'zoom-out' | 'zoom-in' | 'rotate-ccw' | 'rotate-cw' | 'undo-2' | 'arrow-left' | 'arrow-right' | 'arrow-up' | 'arrow-down';

type Props = {
  name: IconName;
  class?: string;
};

const { name, class: className = 'h-5 w-5' } = Astro.props;
---

{name === 'zoom-out' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    <line x1="8" y1="11" x2="14" y2="11"></line>
  </svg>
)}

{name === 'zoom-in' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    <line x1="11" y1="8" x2="11" y2="14"></line>
    <line x1="8" y1="11" x2="14" y2="11"></line>
  </svg>
)}

{name === 'rotate-ccw' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M1 4v6h6"></path>
    <path d="M3.51 15a9 9 0 1 0 .49-9L1 10"></path>
  </svg>
)}

{name === 'rotate-cw' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M23 4v6h-6"></path>
    <path d="M20.49 15a9 9 0 1 1-.49-9L23 10"></path>
  </svg>
)}

{name === 'undo-2' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M9 14 4 9l5-5"></path>
    <path d="M4 9h7a8 8 0 0 1 8 8v3"></path>
  </svg>
)}

{name === 'arrow-left' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m12 19-7-7 7-7"></path>
    <path d="M19 12H5"></path>
  </svg>
)}

{name === 'arrow-right' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m12 5 7 7-7 7"></path>
    <path d="M5 12h14"></path>
  </svg>
)}

{name === 'arrow-up' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m5 12 7-7 7 7"></path>
    <path d="M12 19V5"></path>
  </svg>
)}

{name === 'arrow-down' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m19 12-7 7-7-7"></path>
    <path d="M12 5v14"></path>
  </svg>
)}

---
import type { FrameItem } from '../../../data/events';

type Props = {
  frames: FrameItem[];
  selectedFrameId: string;
};

const { frames, selectedFrameId } = Astro.props;
---

<div class="mx-auto w-full max-w-none sm:max-w-120">
  <div class="rounded-[1.7rem] border border-gray-200 bg-[#f3f4f6] p-3 shadow-[0_20px_40px_rgba(0,0,0,0.12)]">
    <div class="relative aspect-square overflow-hidden rounded-2xl bg-[#111827]">
      <canvas id="preview-canvas" class="h-full w-full touch-none" aria-label="Customized frame preview"></canvas>

      <div
        id="pinch-gesture-tip"
        class="pointer-events-none absolute inset-x-3 bottom-3 hidden rounded-xl border border-[#d2e3fc] bg-white/94 px-3 py-2 text-center text-xs font-semibold text-[#1a73e8] shadow-[0_10px_24px_rgba(26,115,232,0.22)] backdrop-blur-sm sm:hidden"
        role="status"
        aria-live="polite"
      >
        Pinch to zoom. Drag with one finger to move.
        <div class="mt-2 flex items-center justify-center gap-4" aria-hidden="true">
          <span class="pinch-hint-dot pinch-hint-dot--left"></span>
          <span class="pinch-hint-dot pinch-hint-dot--right"></span>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-4 gap-3">
    {frames.map((frame) => (
      <button
        type="button"
        class={`customize-frame-btn aspect-square overflow-hidden rounded-xl border border-gray-200 bg-white p-0 transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 ${frame.id === selectedFrameId ? 'ring-2 ring-[#4285f4]' : ''}`}
        data-frame-id={frame.id}
        data-frame-overlay={frame.overlayPath}
      >
        <img src={frame.thumbnailPath} alt={frame.name} class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </button>
    ))}
  </div>

  <p id="canvas-status" class="mt-3 text-sm text-gray-600">Upload a photo to start customizing.</p>

  <div class="mt-4 sm:hidden">
    <label
      for="photo"
      class="inline-flex w-full cursor-pointer items-center justify-center rounded-full bg-[#4285f4] px-5 py-2.5 text-sm font-bold text-white shadow-[0_10px_22px_rgba(66,133,244,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-[#3d7ae0]"
    >
      Change Photo
    </label>
  </div>
</div>

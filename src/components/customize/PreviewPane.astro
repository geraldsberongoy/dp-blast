---
import type { FrameItem } from '../../../data/events';
import QuickIcon from './QuickIcon.astro';

type Props = {
  frames: FrameItem[];
  selectedFrameId: string;
};

const { frames, selectedFrameId } = Astro.props;
---

<div class="mx-auto w-full max-w-120">
  <div class="rounded-[1.7rem] border border-gray-200 bg-[#f3f4f6] p-3 shadow-[0_20px_40px_rgba(0,0,0,0.12)]">
    <div class="relative aspect-square overflow-hidden rounded-2xl bg-[#111827]">
      <canvas id="preview-canvas" class="h-full w-full" aria-label="Customized frame preview"></canvas>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-4 gap-3">
    {frames.map((frame) => (
      <button
        type="button"
        class={`customize-frame-btn aspect-square overflow-hidden rounded-xl border border-gray-200 bg-white p-0 transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 ${frame.id === selectedFrameId ? 'ring-2 ring-[#4285f4]' : ''}`}
        data-frame-id={frame.id}
        data-frame-overlay={frame.overlayPath}
      >
        <img src={frame.thumbnailPath} alt={frame.name} class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </button>
    ))}
  </div>

  <p id="canvas-status" class="mt-3 text-sm text-gray-600">Upload a photo to start customizing.</p>

  <div class="fixed inset-x-0 bottom-0 z-30 border-t border-gray-200 bg-white/95 px-4 py-3 backdrop-blur sm:hidden">
    <div class="mx-auto flex w-full max-w-96 items-center justify-center gap-2">
      <button
        id="zoom-out-quick"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Zoom out"
      >
        <QuickIcon name="zoom-out" class="h-5 w-5" />
      </button>
      <button
        id="zoom-in-quick"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Zoom in"
      >
        <QuickIcon name="zoom-in" class="h-5 w-5" />
      </button>

      <div class="mx-1 h-8 w-px bg-gray-300" aria-hidden="true"></div>

      <button
        id="rotate-left-quick"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Rotate left"
      >
        <QuickIcon name="rotate-ccw" class="h-5 w-5" />
      </button>
      <button
        id="rotate-right-quick"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Rotate right"
      >
        <QuickIcon name="rotate-cw" class="h-5 w-5" />
      </button>
      <button
        id="reset-quick"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Reset adjustments"
      >
        <QuickIcon name="undo-2" class="h-5 w-5" />
      </button>
    </div>
  </div>
</div>

---
import type { FrameItem } from '../../../data/events';
import QuickIcon from './QuickIcon.astro';

type Props = {
  frames: FrameItem[];
  selectedFrameId: string;
};

const { frames, selectedFrameId } = Astro.props;
---

<div class="mx-auto w-full max-w-120">
  <div class="rounded-[1.7rem] border border-gray-200 bg-[#f3f4f6] p-3 shadow-[0_20px_40px_rgba(0,0,0,0.12)]">
    <div class="relative aspect-square overflow-hidden rounded-2xl bg-[#111827]">
      <canvas id="preview-canvas" class="h-full w-full" aria-label="Customized frame preview"></canvas>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-4 gap-3">
    {frames.map((frame) => (
      <button
        type="button"
        class={`customize-frame-btn aspect-square overflow-hidden rounded-xl border border-gray-200 bg-white p-0 transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 ${frame.id === selectedFrameId ? 'ring-2 ring-[#4285f4]' : ''}`}
        data-frame-id={frame.id}
        data-frame-overlay={frame.overlayPath}
      >
        <img src={frame.thumbnailPath} alt={frame.name} class="h-full w-full object-cover" loading="lazy" decoding="async" />
      </button>
    ))}
  </div>

  <p id="canvas-status" class="mt-3 text-sm text-gray-600">Upload a photo to start customizing.</p>

  <div class="mt-4 sm:hidden">
    <label
      for="photo"
      class="inline-flex w-full cursor-pointer items-center justify-center rounded-full bg-[#4285f4] px-5 py-2.5 text-sm font-bold text-white shadow-[0_10px_22px_rgba(66,133,244,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-[#3d7ae0]"
    >
      Change Photo
    </label>

    <div id="hold-controls-tip" class="mt-3 hidden items-start justify-between gap-3 rounded-xl border border-[#d2e3fc] bg-[#e8f0fe] px-3 py-2 text-sm text-[#1a73e8]" role="status" aria-live="polite">
      <p class="m-0 font-medium">Hold the buttons to adjust</p>
      <button
        id="hold-controls-tip-dismiss"
        type="button"
        class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-[#d2e3fc] bg-white text-xs text-[#1a73e8]"
        aria-label="Dismiss tip"
      >
        x
      </button>
    </div>

    <div class="mt-3 rounded-2xl border border-gray-200 bg-white p-3 shadow-[0_10px_24px_rgba(17,24,39,0.08)]">
      <p class="m-0 text-sm font-semibold text-gray-700">Zoom and Tilt</p>
      <div class="mt-3 grid grid-cols-4 gap-2">
        <button
          id="zoom-out-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Zoom out"
        >
          <QuickIcon name="zoom-out" class="h-5 w-5" />
        </button>
        <button
          id="zoom-in-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Zoom in"
        >
          <QuickIcon name="zoom-in" class="h-5 w-5" />
        </button>
        <button
          id="rotate-left-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Rotate left"
        >
          <QuickIcon name="rotate-ccw" class="h-5 w-5" />
        </button>
        <button
          id="rotate-right-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Rotate right"
        >
          <QuickIcon name="rotate-cw" class="h-5 w-5" />
        </button>
      </div>
    </div>

    <div class="mt-3 rounded-2xl border border-gray-200 bg-white p-3 shadow-[0_10px_24px_rgba(17,24,39,0.08)]">
      <p class="m-0 text-sm font-semibold text-gray-700">Move Position</p>
      <div class="mt-3 grid grid-cols-3 gap-2">
        <div></div>
        <button
          id="move-up-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Move up"
        >
          <QuickIcon name="arrow-up" class="h-5 w-5" />
        </button>
        <div></div>

        <button
          id="move-left-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Move left"
        >
          <QuickIcon name="arrow-left" class="h-5 w-5" />
        </button>
        <button
          id="move-down-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Move down"
        >
          <QuickIcon name="arrow-down" class="h-5 w-5" />
        </button>
        <button
          id="move-right-quick"
          type="button"
          class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
          aria-label="Move right"
        >
          <QuickIcon name="arrow-right" class="h-5 w-5" />
        </button>
      </div>
    </div>

    <div class="mt-3">
      <button
        id="reset-quick"
        type="button"
        class="inline-flex h-11 w-full items-center justify-center rounded-full border border-gray-300 bg-[#111827] text-white"
        aria-label="Reset adjustments"
      >
        <span class="inline-flex items-center gap-2">
          <QuickIcon name="undo-2" class="h-5 w-5" />
          Reset Adjustments
        </span>
      </button>
    </div>
  </div>
</div>

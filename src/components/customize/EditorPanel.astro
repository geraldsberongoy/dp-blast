---
type Props = {
  eventTitle: string;
};

const { eventTitle } = Astro.props;
---

<div>
  <h1 class="m-0 text-3xl font-extrabold tracking-tight md:text-4xl">Customize Your Photo</h1>
  <p class="mt-2 text-base text-gray-600">{eventTitle} · adjust, download, and copy your event caption.</p>

  <input class="sr-only" id="photo" type="file" accept="image/png,image/jpeg,image/webp" />

  <div class="mt-6 hidden rounded-2xl border border-gray-200 bg-gray-50 p-4 md:p-5 sm:block">
    <h2 class="m-0 text-xl font-bold text-[#202124]">Photo Controls</h2>

    <div class="mt-4 flex flex-wrap gap-3">
      <label
        for="photo"
        class="inline-flex cursor-pointer items-center justify-center rounded-full bg-[#4285f4] px-5 py-2.5 text-sm font-bold text-white shadow-[0_10px_22px_rgba(66,133,244,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-[#3d7ae0]"
      >
        Change Photo
      </label>
      <button
        id="reset-adjustments"
        type="button"
        class="inline-flex items-center justify-center rounded-full border border-gray-300 bg-white px-5 py-2.5 text-sm font-bold text-gray-700 transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-gray-100"
      >
        Reset Adjustments
      </button>
    </div>

    <div id="advanced-controls-panel" class="mt-5 grid gap-4">
      <div>
        <div class="mb-1 flex items-center justify-between text-sm text-gray-600">
          <label for="zoom-range" class="font-semibold text-gray-700">Zoom</label>
          <span id="zoom-value">1.00x</span>
        </div>
        <input id="zoom-range" type="range" min="0.5" max="2.8" step="0.01" value="1" class="w-full accent-[#4285f4]" />
      </div>

      <div>
        <div class="mb-1 flex items-center justify-between text-sm text-gray-600">
          <label for="x-range" class="font-semibold text-gray-700">Horizontal</label>
          <span id="x-value">0px</span>
        </div>
        <input id="x-range" type="range" min="-500" max="500" step="1" value="0" class="w-full accent-[#ea4335]" />
      </div>

      <div>
        <div class="mb-1 flex items-center justify-between text-sm text-gray-600">
          <label for="y-range" class="font-semibold text-gray-700">Vertical</label>
          <span id="y-value">0px</span>
        </div>
        <input id="y-range" type="range" min="-500" max="500" step="1" value="0" class="w-full accent-[#34a853]" />
      </div>

      <div>
        <div class="mb-1 flex items-center justify-between text-sm text-gray-600">
          <label for="tilt-range" class="font-semibold text-gray-700">Tilt</label>
          <span id="tilt-value">0deg</span>
        </div>
        <input id="tilt-range" type="range" min="-180" max="180" step="1" value="0" class="w-full accent-[#fbbc04]" />
      </div>
    </div>
  </div>

  <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-4 md:p-5">
    <h2 class="m-0 text-xl font-bold text-[#202124]">Event Caption</h2>
    <p class="m-0 mt-2 text-sm text-gray-600">Edit your name and copy this caption when sharing your DP.</p>

    <div class="mt-4 grid gap-2">
      <label for="caption-name" class="text-sm font-semibold text-gray-700">Your name</label>
      <input
        id="caption-name"
        type="text"
        value="Your Name"
        class="w-full rounded-xl border border-gray-300 bg-white px-3 py-2 text-base text-gray-800 outline-none focus-visible:border-[#4285f4] focus-visible:shadow-[0_0_0_3px_rgba(66,133,244,0.2)]"
      />
    </div>

    <div class="mt-4 grid gap-2">
      <label for="caption-output" class="text-sm font-semibold text-gray-700">Generated caption</label>
      <textarea
        id="caption-output"
        rows="6"
        readonly
        class="w-full rounded-xl border border-gray-300 bg-gray-50 px-3 py-2 text-sm leading-relaxed text-gray-700 outline-none"
      ></textarea>
    </div>

    <div class="mt-4 flex items-center gap-3 max-sm:flex-col max-sm:items-stretch">
      <button
        id="caption-copy"
        type="button"
        class="inline-flex items-center justify-center rounded-full bg-[#34a853] px-4 py-2 text-sm font-bold text-white shadow-[0_8px_20px_rgba(52,168,83,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-[#2f974b]"
      >
        Copy Caption
      </button>
      <p id="caption-status" class="m-0 text-sm text-gray-600">Caption is ready.</p>
    </div>
  </div>

  <button
    id="download-result"
    type="button"
    class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[#4285f4] px-5 py-3 text-sm font-bold text-white shadow-[0_12px_24px_rgba(66,133,244,0.3)] transition-transform duration-200 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:-translate-y-0.5 hover:bg-[#3d7ae0]"
  >
    Download Customized DP
  </button>
</div>

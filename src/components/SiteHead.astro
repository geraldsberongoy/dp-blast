---
interface Props {
  title: string;
  description?: string;
  imagePath?: string;
  siteName?: string;
}

const {
  title,
  description = 'Upload your photo, apply a frame, and download a profile-ready image in seconds.',
  imagePath = '/logo.png',
  siteName = 'GDG DP Blast',
} = Astro.props;

const pageUrl = Astro.url.toString();
const imageUrl = new URL(imagePath, Astro.url).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="theme-color" content="#4285f4" />

<link rel="canonical" href={pageUrl} />

<link rel="icon" type="image/png" href="/logo.png" />
<link rel="shortcut icon" href="/logo.png" />
<link rel="apple-touch-icon" href="/logo.png" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={pageUrl} />
<meta property="og:image" content={imageUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<title>{title}</title>

<script is:inline>
  (() => {
    const USER_NAME_KEY = 'dpblast-user-name';
    const MODAL_ID = 'dpblast-name-modal';

    const hasStoredName = () => {
      try {
        const existingName = localStorage.getItem(USER_NAME_KEY);
        return Boolean(existingName && existingName.trim());
      } catch {
        return false;
      }
    };

    const persistName = (value) => {
      const normalizedName = value && value.trim() ? value.trim() : 'Sparkmate';
      try {
        localStorage.setItem(USER_NAME_KEY, normalizedName);
      } catch {
        // Ignore storage issues and keep the UX flowing.
      }
    };

    const closeModal = (modal) => {
      modal.classList.remove('is-open');
      modal.classList.add('is-closing');

      const removeModal = () => {
        if (modal.parentNode) {
          modal.parentNode.removeChild(modal);
        }
      };

      window.setTimeout(removeModal, 260);
    };

    const mountNameModal = (forceOpen = false) => {
      if (document.getElementById(MODAL_ID)) return;

      if (!forceOpen && hasStoredName()) {
        return;
      }

      let currentName = '';
      const escapedName = (value) =>
        value
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      try {
        currentName = localStorage.getItem(USER_NAME_KEY) || '';
      } catch {
        currentName = '';
      }

      const modal = document.createElement('div');
      modal.id = MODAL_ID;
      modal.className = 'dpblast-name-modal';
      modal.innerHTML = `
        <div class="dpblast-name-modal__backdrop" aria-hidden="true"></div>
        <div class="dpblast-name-modal__card" role="dialog" aria-modal="true" aria-labelledby="dpblast-name-title">
          <h2 id="dpblast-name-title" class="dpblast-name-modal__title">Hi sparkmate! What's your name?</h2>
          <p class="dpblast-name-modal__copy">We will use your name when generating event captions.</p>

          <form id="dpblast-name-form" class="dpblast-name-modal__form">
            <label class="dpblast-name-modal__label" for="dpblast-name-input">Your name</label>
            <input id="dpblast-name-input" class="dpblast-name-modal__input" type="text" placeholder="Type your name" maxlength="80" autocomplete="name" value="${escapedName(currentName)}" />

            <div class="dpblast-name-modal__actions">
              <button type="submit" class="dpblast-name-modal__btn dpblast-name-modal__btn--primary">Save Name</button>
              <button type="button" id="dpblast-name-skip" class="dpblast-name-modal__btn dpblast-name-modal__btn--secondary">Continue as Sparkmate</button>
            </div>
          </form>
        </div>
      `;

      document.body.appendChild(modal);
      window.requestAnimationFrame(() => {
        modal.classList.add('is-open');
      });

      const form = modal.querySelector('#dpblast-name-form');
      const input = modal.querySelector('#dpblast-name-input');
      const skipButton = modal.querySelector('#dpblast-name-skip');
      const backdrop = modal.querySelector('.dpblast-name-modal__backdrop');

      if (input instanceof HTMLInputElement) {
        window.setTimeout(() => input.focus(), 80);
      }

      if (form instanceof HTMLFormElement) {
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          const value = input instanceof HTMLInputElement ? input.value : '';
          persistName(value);
          closeModal(modal);
        });
      }

      if (skipButton instanceof HTMLButtonElement) {
        skipButton.addEventListener('click', () => {
          persistName('Sparkmate');
          closeModal(modal);
        });
      }

      if (backdrop instanceof HTMLDivElement) {
        backdrop.addEventListener('click', () => {
          closeModal(modal);
        });
      }

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeModal(modal);
        }
      }, { once: true });
    };

    window.dpblastOpenNameModal = () => {
      mountNameModal(true);
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest('[data-edit-name-trigger]');
      if (!trigger) return;

      event.preventDefault();
      window.dpblastOpenNameModal();
    });

    if (hasStoredName()) {
      return;
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => mountNameModal(false), { once: true });
    } else {
      mountNameModal(false);
    }
  })();
</script>

<style is:global>
  .dpblast-name-modal {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    pointer-events: none;
    opacity: 0;
  }

  .dpblast-name-modal.is-open {
    pointer-events: auto;
    animation: magicuiFadeIn 220ms ease forwards;
  }

  .dpblast-name-modal.is-closing {
    pointer-events: none;
    animation: magicuiFadeOut 220ms ease forwards;
  }

  .dpblast-name-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(6px);
  }

  .dpblast-name-modal__card {
    position: relative;
    width: min(100%, 34rem);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.96);
    padding: 1.25rem;
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.36);
    transform: translateY(14px) scale(0.97);
  }

  .dpblast-name-modal.is-open .dpblast-name-modal__card {
    animation: magicuiScaleIn 260ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .dpblast-name-modal.is-closing .dpblast-name-modal__card {
    animation: magicuiScaleOut 200ms ease forwards;
  }

  .dpblast-name-modal__title {
    margin: 0;
    font-size: clamp(1.25rem, 3.3vw, 1.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 900;
    color: #202124;
  }

  .dpblast-name-modal__copy {
    margin: 0.5rem 0 0;
    color: #4b5563;
    font-size: 0.93rem;
  }

  .dpblast-name-modal__form {
    margin-top: 1rem;
  }

  .dpblast-name-modal__label {
    display: block;
    margin: 0 0 0.45rem;
    font-size: 0.86rem;
    font-weight: 700;
    color: #374151;
  }

  .dpblast-name-modal__input {
    width: 100%;
    border-radius: 0.8rem;
    border: 1px solid #d1d5db;
    background: #fff;
    padding: 0.7rem 0.85rem;
    font-size: 1rem;
    color: #1f2937;
    outline: none;
  }

  .dpblast-name-modal__input:focus {
    border-color: #4285f4;
    box-shadow: 0 0 0 3px rgba(66, 133, 244, 0.2);
  }

  .dpblast-name-modal__actions {
    margin-top: 0.9rem;
    display: flex;
    gap: 0.5rem;
  }

  .dpblast-name-modal__btn {
    flex: 1;
    border-radius: 9999px;
    border: 1px solid transparent;
    padding: 0.63rem 0.8rem;
    font-size: 0.86rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1), background-color 180ms ease;
  }

  .dpblast-name-modal__btn:hover {
    transform: translateY(-1px);
  }

  .dpblast-name-modal__btn--primary {
    background: #4285f4;
    color: #fff;
  }

  .dpblast-name-modal__btn--primary:hover {
    background: #3d7ae0;
  }

  .dpblast-name-modal__btn--secondary {
    border-color: #d1d5db;
    background: #fff;
    color: #374151;
  }

  .dpblast-name-modal__btn--secondary:hover {
    background: #f9fafb;
  }

  @media (max-width: 480px) {
    .dpblast-name-modal__actions {
      flex-direction: column;
    }
  }

  @keyframes magicuiFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes magicuiFadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  @keyframes magicuiScaleIn {
    from {
      transform: translateY(14px) scale(0.97);
      opacity: 0;
    }
    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  @keyframes magicuiScaleOut {
    from {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
    to {
      transform: translateY(8px) scale(0.985);
      opacity: 0;
    }
  }
</style>